4:["$","div",null,{"className":"blog-detail-root","children":[["$","$Lf",null,{}],["$","$L10",null,{}],["$","main",null,{"className":"blog-detail-main","children":[["$","div",null,{"className":"grain-overlay"}],["$","div",null,{"className":"container container--narrow","children":[["$","$L11",null,{"href":"/#blog","className":"blog-detail-back","children":[["$","svg",null,{"width":"16","height":"16","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":"2.5","strokeLinecap":"round","strokeLinejoin":"round","children":[["$","line",null,{"x1":"19","y1":"12","x2":"5","y2":"12"}],["$","polyline",null,{"points":"12 19 5 12 12 5"}]]}],"Back to Journal"]}],["$","header",null,{"className":"blog-detail-header","children":[["$","span",null,{"className":"blog-detail-category label","children":"Culinary Innovation"}],["$","h1",null,{"className":"blog-detail-title","children":"The Art of Vegan Cheese Crafting"}],["$","div",null,{"className":"blog-detail-meta","children":[["$","span",null,{"children":["Published on ","May 15, 2026"]}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"By Chef Akanksha"}]]}]]}],["$","div",null,{"className":"blog-detail-img-wrapper","children":["$","img",null,{"src":"/images/vegan-cheese-icon.png","alt":"The Art of Vegan Cheese Crafting","className":"blog-detail-img"}]}],["$","article",null,{"className":"blog-detail-content","children":[["$","p","0",{"children":"Cheese is the soul of Italian cuisine. When I set out to specialize in plant-based Italian cooking, the biggest challenge wasn't the pasta, but the cheese. How could you replicate the stretch of fresh mozzarella or the deep umami of aged Parmigiano-Reggiano without dairy?"}],["$","p","1",{"children":"Most commercial vegan cheeses rely on starches and oils. They melt, but they lack soul. I wanted to treat plant-based cheese-making like a traditional craft."}],["$","p","2",{"children":"By leveraging raw cashews, almonds, and homemade rejuvelac (a fermented grain liquid), I began aging cheeses in controlled settings. The result was remarkable: we developed lactic acidity, complex rind structures, and a natural melt that rivals traditional cheeses."}],["$","p","3",{"children":"In this blog, we explore the step-by-step fermentation science behind cashew-based mozzarella and how small-batch plant cheese can elevate restaurant menus."}]]}]]}]]}],["$","$L12",null,{}]]}]
