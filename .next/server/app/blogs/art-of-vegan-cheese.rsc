8:{"metadata":[["$","title","0",{"children":"The Art of Vegan Cheese Crafting — Chef Akanksha"}],["$","meta","1",{"name":"description","content":"How understanding fermentation and traditional Italian dairy methods helped unlock rich, melting, plant-based mozzarella and aged parmesan."}],["$","meta","2",{"property":"og:title","content":"Chef Akanksha — Good for you. Kind for them."}],["$","meta","3",{"property":"og:description","content":"Plant-based goodness, made with love. 100% Vegan cuisine crafted with compassion."}],["$","meta","4",{"property":"og:type","content":"website"}],["$","meta","5",{"name":"twitter:card","content":"summary"}],["$","meta","6",{"name":"twitter:title","content":"Chef Akanksha — Good for you. Kind for them."}],["$","meta","7",{"name":"twitter:description","content":"Plant-based goodness, made with love. 100% Vegan cuisine crafted with compassion."}]],"error":null,"digest":"$undefined"}
